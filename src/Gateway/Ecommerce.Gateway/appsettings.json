{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "basket-route": {
        "ClusterId": "basket-cluster",
        "Match": {
          "Path": "/basket/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/basket/{**catch-all}"
          }
        ]
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/orders/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/orders/{**catch-all}"
          }
        ]
      },
      "logistics-route": {
        "ClusterId": "logistics-cluster",
        "Match": {
          "Path": "/logistics/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/logistics/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "basket-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5020/"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5030/"
          }
        }
      },
      "logistics-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5040/"
          }
        }
      }
    }
  }
}
