{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "basket-route": {
        "ClusterId": "basket-cluster",
        "Match": {
          "Path": "/basket/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/basket/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "basket-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https+http://basket-api"
          }
        }
      }
    }
  }
}
